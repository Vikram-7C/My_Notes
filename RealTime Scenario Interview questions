public with sharing class ContactTriggerHandler {
    public static void updateAccountContactCount( List<Contact> newList, Map<Id, Contact> oldMap) {
        Set<Id> accountIds = new Set<Id>();
        // Insert & Undelete
        if (newList != null && oldMap == null) {
            for (Contact con : newList) {
                if (con.AccountId != null) {
                    accountIds.add(con.AccountId);
                }
            }
        }
        // Delete
        if (newList == null && oldMap != null) {
            for (Contact con : oldMap.values()) {
                if (con.AccountId != null) {
                    accountIds.add(con.AccountId);
                }
            }
        }
        // Update
        if (newList != null && oldMap != null) {
            for (Contact newCon : newList) {
                Contact oldCon = oldMap.get(newCon.Id);
                if (newCon.AccountId != oldCon.AccountId) {
                    if (newCon.AccountId != null) {
                        accountIds.add(newCon.AccountId);
                    }
                    if (oldCon.AccountId != null) {
                        accountIds.add(oldCon.AccountId);
                    }
                }
            }
        }

        if (accountIds.isEmpty()) {
            return;
        }

        // Aggregate Query
        Map<Id, Integer> contactCountMap = new Map<Id, Integer>();

        for (AggregateResult ar : [ SELECT AccountId, COUNT(Id) totalContacts FROM ContactWHERE AccountId IN :accountIds
                                   GROUP BY AccountId ]) {
            contactCountMap.put( (Id) ar.get('AccountId'),
                (Integer) ar.get('totalContacts')
            );
        }

        List<Account> accountsToUpdate = new List<Account>();

        for (Account acc : [
            SELECT Id, Number_of_Contacts__c
            FROM Account
            WHERE Id IN :accountIds
        ]) {

            Integer latestCount = contactCountMap.containsKey(acc.Id)
                ? contactCountMap.get(acc.Id)
                : 0;

            if (acc.Number_of_Contacts__c != latestCount) {
                acc.Number_of_Contacts__c = latestCount;
                accountsToUpdate.add(acc);
            }
        }

        if (!accountsToUpdate.isEmpty()) {
            update accountsToUpdate;
        }
    }
}