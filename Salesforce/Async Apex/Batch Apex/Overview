11. Database.Stateful

Normally

Variables reset every execute().

Example

Integer total=0;

Execute 1

200 records

total=200

Execute 2

Variable becomes

0

Again.

Need total records?

Implement

Database.Stateful

Example

global class BatchDemo
implements Database.Batchable<SObject>,
Database.Stateful
{
    Integer total=0;

    global void execute(...)
    {
        total+=scope.size();
    }

    global void finish(...)
    {
        System.debug(total);
    }
}

